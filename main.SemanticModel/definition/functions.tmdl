function GetQuarterStart =
		(_date : DATETIME) =>
				DATE(YEAR(_date), (3*int((MONTH(_date)-1)/3))+1, 1)
	lineageTag: 9f2082a5-58c3-4797-aa8d-d010fedec343

function GetQuarterNumber =
		(_date : DATETIME) =>
				int((MONTH(_date)-1)/3)+1
	lineageTag: af31cdf5-dc83-4ea9-95ba-cc18c0cda62b

function GetWeekStart =
		(_date : DATETIME) =>
				_date - WEEKDAY(_date,2) + 1
	lineageTag: 30ed14b6-6aaa-4ef7-8684-b1a5e96d092e

function GetMeasureDirectionm =
		(_measure : STRING) =>
				CALCULATE(
					FIRSTNONBLANK(_MeasureCatalog[Direction], 1),
					FILTER(_MeasureCatalog, _MeasureCatalog[Metric Name]=_measure)
				)
	lineageTag: a5fed73e-033f-4e87-ae90-e2a5b8bccbe4

function FormatMeasure =
		(_measure : STRING) =>
			SWITCH(_measure,
				"Sales - Actual", "#,000",
				"Sales - Goal (FactSalesQuota)", "#,000",
				"Sales - Goal Achievement %", "0.00%",
				"Sales - Strategic Plan Goal","#,000",
				"Sales - vs Strategic Plan %",  "0.00%",
				"Units - Actual", "#,000",
				"Units - Goal (FactSalesQuota)", "#,000",
				"Units - Goal Achievement %",  "0.00%",
				"Units - Store", "#,000",
				"Units - Online", "#,000",
				"Gross Profit - Goal Achievement %",  "0.00%",
				"Gross Margin %",  "0.00%",
				"Sales - Store Channel", "#,000",
				"Sales - Online Channel", "#,000",
				"Online Sales % of Total",  "0.00%",
				"Store Sales % of Total",  "0.00%",
				"Discount Rate % of Sales",  "0.00%",
				"Return Rate % of Sales",  "0.00%",
				"Customers - Unique", "#,000",
				"Stores - Count", "#,000",
				"Machine - Count with Downtime", "#,000",
				"Machine - Outage Incidents", "#,000",
				"Machine - Preventive % of Total Cost",  "0.00%",
				"Machine - SLA Uptime Goal %",  "0.00%",
				"Machine - Actual Uptime %",  "0.00%",
				"Machine - SLA Compliance %",  "0.00%",
				"HR - Employees Total", "#,000",
				"#,000.00"
		)
	lineageTag: 5524b679-854a-4ce8-bd85-c3faefa0b51c

