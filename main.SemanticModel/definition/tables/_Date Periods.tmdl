	column Type
		lineageTag: c12ce88c-a3fc-4ced-a1a3-8390cb2869dc
		summarizeBy: none
		isNameInferred
		sourceColumn: [Type]

		annotation SummarizationSetBy = Automatic

	column Date
		formatString: General Date
		lineageTag: 334a9b6f-7b32-4d37-847f-3e02d28b7570
		summarizeBy: none
		isNameInferred
		sourceColumn: [Date]

		annotation SummarizationSetBy = Automatic

	column Order
		formatString: 0
		lineageTag: 21314aae-c3f2-49a6-a5a1-3ab5ca66690a
		summarizeBy: sum
		isNameInferred
		sourceColumn: [Order]

