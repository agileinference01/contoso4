	partition DimCalendar = calculated
		mode: import
		source =
				
				var _max = MAX(CALCULATE(MAX(FactOnlineSales[DateKey]), all(FactOnlineSales[DateKey])), CALCULATE(MAX(FactSales[DateKey]), all(FactSales[DateKey])))
				var _min = Min(CALCULATE(Min(FactOnlineSales[DateKey]), all(FactOnlineSales[DateKey])), CALCULATE(min(FactSales[DateKey]), all(FactSales[DateKey])))
				RETURN
				FILTER(DimDate, DimDate[DateKey]>=_min && DimDate[DateKey]<=_max)

	annotation PBI_Id = db51baec8ffc42ea9b43efccdb96bf93

